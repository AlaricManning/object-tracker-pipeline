{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListRawAndCatalogOnly",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::object-tracker-am",
      "Condition": {
        "StringLike": {
          "s3:prefix": ["raw/*", "catalog/*", "athena-results/*"]
        }
      }
    },
    {
      "Sid": "ReadRawClips",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::object-tracker-am/raw/*"
    },
    {
      "Sid": "ReadWriteCatalog",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject"],
      "Resource": "arn:aws:s3:::object-tracker-am/catalog/*"
    },
    {
      "Sid": "AthenaResults",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject"],
      "Resource": "arn:aws:s3:::object-tracker-am/athena-results/*"
    },
    {
      "Sid": "BucketLocationForAthena",
      "Effect": "Allow",
      "Action": "s3:GetBucketLocation",
      "Resource": "arn:aws:s3:::object-tracker-am"
    },
    {
      "Sid": "AthenaQuerying",
      "Effect": "Allow",
      "Action": [
        "athena:StartQueryExecution",
        "athena:GetQueryExecution",
        "athena:GetQueryResults",
        "athena:StopQueryExecution",
        "athena:GetWorkGroup"
      ],
      "Resource": "arn:aws:athena:*:*:workgroup/primary"
    },
    {
      "Sid": "GlueReadDetectionsTable",
      "Effect": "Allow",
      "Action": ["glue:GetDatabase", "glue:GetTable", "glue:GetPartitions"],
      "Resource": [
        "arn:aws:glue:*:*:catalog",
        "arn:aws:glue:*:*:database/object_tracker",
        "arn:aws:glue:*:*:table/object_tracker/detections"
      ]
    }
  ]
}
